{
	"name": "pl_ingest_bronze",
	"properties": {
		"activities": [
			{
				"name": "ForEach1",
				"type": "ForEach",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@pipeline().parameters.fileList",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "Copy data1",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.12:00:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "DelimitedTextSource",
									"storeSettings": {
										"type": "AzureBlobFSReadSettings",
										"recursive": true,
										"wildcardFileName": {
											"value": "@item().source",
											"type": "Expression"
										},
										"enablePartitionDiscovery": false
									},
									"formatSettings": {
										"type": "DelimitedTextReadSettings"
									}
								},
								"sink": {
									"type": "DelimitedTextSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings",
										"copyBehavior": "PreserveHierarchy"
									},
									"formatSettings": {
										"type": "DelimitedTextWriteSettings",
										"quoteAllText": true,
										"fileExtension": ".csv"
									}
								},
								"enableStaging": false,
								"translator": {
									"type": "TabularTranslator",
									"typeConversion": true,
									"typeConversionSettings": {
										"allowDataTruncation": true,
										"treatBooleanAsNumber": false
									}
								}
							},
							"inputs": [
								{
									"referenceName": "ds_bronze_source_csv",
									"type": "DatasetReference"
								}
							],
							"outputs": [
								{
									"referenceName": "ds_bronze_sink_csv",
									"type": "DatasetReference",
									"parameters": {
										"sink_folder": {
											"value": "@item().sink_folder",
											"type": "Expression"
										}
									}
								}
							]
						}
					]
				}
			}
		],
		"parameters": {
			"fileList": {
				"type": "array",
				"defaultValue": [
					{
						"source": "patients.csv",
						"sink_folder": "patient"
					},
					{
						"source": "admissions.csv",
						"sink_folder": "visit"
					},
					{
						"source": "diagnoses_icd.csv",
						"sink_folder": "diagnosis"
					},
					{
						"source": "d_icd_diagnoses.csv",
						"sink_folder": "diagnosis"
					},
					{
						"source": "insurance.csv",
						"sink_folder": "billing"
					},
					{
						"source": "Doctors.csv",
						"sink_folder": "doctors"
					},
					{
						"source": "Departments.csv",
						"sink_folder": "departments"
					}
				]
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-03-05T10:58:27Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}